    "manages_department_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d4\u05de\u05d7\u05dc\u05e7\u05d4 \u05e9\u05d4\u05ea\u05e4\u05e7\u05d9\u05d3 \u05de\u05e0\u05d4\u05dc (\u05d0\u05dd is_manager=true)"
    },
    "manages_department_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05de\u05d7\u05dc\u05e7\u05d4 \u05e9\u05d4\u05ea\u05e4\u05e7\u05d9\u05d3 \u05de\u05e0\u05d4\u05dc"
